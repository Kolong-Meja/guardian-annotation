{
  "name": "@revenziel/guardian",
  "version": "1.0.0",
  "license": "GPL-3.0-only",
  "exports": "./mod.ts",
  "tasks": {
    "start": "deno run --allow-env src/main.ts",
    "dev": "deno run --allow-env --watch src/main.ts",
    "format": "deno fmt",
    "lint": "deno lint",
    "check-format": "deno fmt --check",
    "test": "deno test",
    "check": "deno check mod.ts",
    "publish:dry": "deno publish --dry-run"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.13"
  },
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "lib": ["ESNext", "deno.window"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "publish": {
    "include": ["mod.ts", "src/**/*.ts", "README.md", "LICENSE", "deno.json"],
    "exclude": ["__tests__/**", "**/*_test.ts"]
  }
}
